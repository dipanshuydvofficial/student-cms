<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In · SMS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      background: #F4F7FE;
    }
    .login-card {
      background: #ffffff;
      padding: 50px 40px;
      border-radius: 24px;
      box-shadow: 0 10px 40px rgba(43, 54, 116, 0.08);
      max-width: 420px;
      width: 100%;
    }
    .logo-box {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #ffffff;
      font-weight: 700;
      font-size: 26px;
      margin: 0 auto 22px;
      letter-spacing: 0;
    }
    .login-card h2 {
      color: #2B3674;
      font-weight: 700;
      text-align: center;
      margin-bottom: 6px;
      font-size: 26px;
    }
    .subtitle {
      color: #A3AED0;
      text-align: center;
      margin-bottom: 28px;
      font-size: 14px;
    }
    .form-control {
      background: #F8FAFC;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      color: #2B3674;
      margin-bottom: 14px;
      transition: all 0.15s ease;
    }
    .form-control::placeholder { color: #A3AED0; }
    .form-control:focus {
      background: #F8FAFC;
      border-color: #6366F1;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
      outline: none;
    }
    .btn-signin {
      background: #6366F1;
      color: #ffffff;
      border: none;
      border-radius: 12px;
      padding: 12px;
      width: 100%;
      font-weight: 600;
      font-size: 15px;
      margin-top: 6px;
      transition: background 0.15s ease;
    }
    .btn-signin:hover { background: #4F46E5; color: #ffffff; }
    .alert { border-radius: 12px; font-size: 14px; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">S</div>
    <h2>Welcome Back</h2>
    <p class="subtitle">Student Management System</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" role="alert"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" autocomplete="off">
      <input type="email" name="email" class="form-control" placeholder="Email address" required />
      <input type="password" name="password" class="form-control" placeholder="Password" required />
      <button type="submit" class="btn btn-signin">Sign In</button>
    </form>
  </div>
</body>
</html>
